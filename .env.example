# =============================================================================
# AI Gateway — Environment Variables
# =============================================================================
# Copy this file to .env and update values for your environment.
# NEVER commit .env — it contains secrets. This template is safe to commit.
# =============================================================================

# --- Application ---
APP_NAME=ai-gateway
ENVIRONMENT=dev
DEBUG=true
PORT=8100

# --- Cloud Provider ---
# Options: aws, azure, local
CLOUD_PROVIDER=local

# --- Routing Strategy ---
# Options: single, fallback, cost, round
ROUTING_STRATEGY=single

# --- AWS Bedrock ---
AWS_REGION=eu-west-1
AWS_BEDROCK_MODEL_ID=anthropic.claude-3-5-sonnet-20241022-v2:0
AWS_BEDROCK_EMBED_MODEL_ID=amazon.titan-embed-text-v2:0

# --- Azure OpenAI ---
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-10-21
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_EMBED_DEPLOYMENT=text-embedding-3-small

# --- Local (Ollama) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# --- Redis (Cache + Rate Limiting) ---
REDIS_URL=redis://localhost:6379/0
CACHE_ENABLED=true
CACHE_TTL_SECONDS=3600
CACHE_SIMILARITY_THRESHOLD=0.92
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS_PER_MINUTE=60

# --- PostgreSQL (Usage Tracking) ---
DATABASE_URL=postgresql+asyncpg://gateway:gateway@localhost:5432/ai_gateway

# --- API Keys ---
API_KEYS_ENABLED=false
MASTER_API_KEY=gw-dev-key-12345

# --- LangFuse (Observability) ---
LANGFUSE_ENABLED=false
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3000

# --- Cost Tracking ---
COST_TRACKING_ENABLED=true

# --- Fallback ---
FALLBACK_PROVIDER=local
FALLBACK_MAX_RETRIES=2
FALLBACK_TIMEOUT_SECONDS=30.0

# =============================================================================
# Config-tuning labs
# See docs/hands-on-labs/hands-on-labs-config-tuning.md
# App code does not yet read these — wiring them up is part of running each lab.
# =============================================================================
LLM_TEMPERATURE=0.0
LLM_MAX_TOKENS=1024
SYSTEM_PROMPT_MODE=strict       # strict|lax
